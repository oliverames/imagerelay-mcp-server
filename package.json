{
  "name": "imagerelay-mcp-server",
  "version": "2.0.2",
  "description": "MCP server for Image Relay API integration — complete API coverage with 90+ tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "imagerelay-mcp-server": "dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "image-relay",
    "digital-asset-management",
    "dam",
    "api"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oliverames/imagerelay-mcp-server.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
